AI_API_KEY=
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL=meta/llama-3.3-70b-instruct
AI_TEMPERATURE=0.2
AI_TOP_P=0.7
AI_MAX_TOKENS=6144
AI_STREAM=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# E-mail via Resend (opcional — envia se as 3 variáveis estiverem preenchidas)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
EMAIL_FROM=DevBrief News <noreply@rmsys.com.br>
EMAIL_TO=destinatario@exemplo.com
EMAIL_LOGO_URL=https://devbrief-news.vercel.app/assets/logo.png

# Múltiplos destinatários separados por vírgula:
# EMAIL_TO=email1@exemplo.com,email2@exemplo.com

# Opcional: fuso horário do agendamento local (padrão: America/Sao_Paulo)
TIMEZONE=America/Sao_Paulo

# Opcional: horário diário no formato HH:MM (padrão: 07:00)
SCHEDULE_TIME=07:00

# --- PostgreSQL (Neon) ---
DATABASE_URL=postgresql://usuario:senha@host/neondb?sslmode=require

# Sync do site (cron-job.org a cada 5 min → /api/sync)
SYNC_MAX_AGE_HOURS=24

# Segredo para proteger endpoints de cron (gere com: openssl rand -hex 32)
CRON_SECRET=

# Upstash Redis (recomendado na Vercel para não reenviar alertas duplicados)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sensibilidade dos alertas urgentes
BREAKING_MAX_AGE_HOURS=3
BREAKING_MIN_SCORE=5
BREAKING_MAX_CANDIDATES=5
ALERT_TTL_SECONDS=259200
