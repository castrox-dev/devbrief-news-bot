{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "api/daily.py", "use": "@vercel/python" },
    { "src": "api/breaking.py", "use": "@vercel/python" },
    { "src": "api/health.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/daily", "dest": "api/daily.py" },
    { "src": "/api/breaking", "dest": "api/breaking.py" },
    { "src": "/api/health", "dest": "api/health.py" }
  ],
  "crons": [
    {
      "path": "/api/daily",
      "schedule": "0 10 * * *"
    }
  ]
}
